# Required on the server. Never commit the real key.
OPENAI_API_KEY=your_openai_api_key

# Optional. Defaults to gpt-5-mini.
OPENAI_MODEL=gpt-5-mini

# Optional comma-separated origins when the frontend and API use different domains.
# Example: https://xieyaozhong.github.io,https://your-project.vercel.app
ALLOWED_ORIGINS=
